{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "READ",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git -C * status)",
      "Bash(git log:*)",
      "Bash(git -C * log)",
      "Bash(git diff:*)",
      "Bash(git -C * diff)",
      "Bash(git branch:*)",
      "Bash(git -C * branch)",
      "Bash(git checkout:*)",
      "Bash(git -C * checkout)",
      "Bash(git switch:*)",
      "Bash(git -C * switch)",
      "Bash(git add:*)",
      "Bash(git -C * add)",
      "Bash(git commit:*)",
      "Bash(git -C * commit)",
      "Bash(git pull:*)",
      "Bash(git -C * pull)",
      "Bash(git fetch:*)",
      "Bash(git -C * fetch)",
      "Bash(git stash:*)",
      "Bash(git -C * stash)",
      "Bash(git merge:*)",
      "Bash(git -C * merge)",
      "Bash(git rebase:*)",
      "Bash(git -C * rebase)",
      "Bash(git cherry-pick:*)",
      "Bash(git -C * cherry-pick)",
      "Bash(git show:*)",
      "Bash(git -C * show)",
      "Bash(git blame:*)",
      "Bash(git -C * blame)",
      "Bash(git init:*)",
      "Bash(git -C * init)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(poetry:*)",
      "Bash(uv:*)",
      "Bash(cargo:*)",
      "Bash(go :*)",
      "Bash(make:*)",
      "Bash(gh :*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(rm :*-f:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=/dev:*)",
      "Bash(git push:*)",
      "Bash(git -C * push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f :*)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(rm :*)",
      "Bash(sudo rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(chmod 777:*)",
      "Bash(git clone:*)",
      "Bash(git -C * clone:*)",
      "Bash(git remote:*)",
      "Bash(git -C * remote:*)",
      "Bash(git tag:*)",
      "Bash(git -C * tag:*)"
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {}
}
