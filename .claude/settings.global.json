{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "READ",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git -C * status)",
      "Bash(git log:*)",
      "Bash(git -C * log)",
      "Bash(git diff:*)",
      "Bash(git -C * diff)",
      "Bash(git branch:*)",
      "Bash(git -C * branch)",
      "Bash(git checkout:*)",
      "Bash(git -C * checkout)",
      "Bash(git switch:*)",
      "Bash(git -C * switch)",
      "Bash(git add:*)",
      "Bash(git -C * add)",
      "Bash(git commit:*)",
      "Bash(git -C * commit)",
      "Bash(git pull:*)",
      "Bash(git -C * pull)",
      "Bash(git fetch:*)",
      "Bash(git -C * fetch)",
      "Bash(git stash:*)",
      "Bash(git -C * stash)",
      "Bash(git merge:*)",
      "Bash(git -C * merge)",
      "Bash(git rebase:*)",
      "Bash(git -C * rebase)",
      "Bash(git cherry-pick:*)",
      "Bash(git -C * cherry-pick)",
      "Bash(git show:*)",
      "Bash(git -C * show)",
      "Bash(git blame:*)",
      "Bash(git -C * blame)",
      "Bash(git init:*)",
      "Bash(git -C * init)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(poetry:*)",
      "Bash(uv:*)",
      "Bash(cargo:*)",
      "Bash(go :*)",
      "Bash(make:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh search:*)",
      "Bash(gh label list:*)",
      "Bash(gh auth status:*)",
      "Bash(gh status:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(rm :*-f:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=/dev:*)",
      "Bash(git push:*)",
      "Bash(git -C * push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f :*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr lock:*)",
      "Bash(gh pr unlock:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo fork:*)",
      "Bash(gh release create:*)",
      "Bash(gh release edit:*)",
      "Bash(gh release upload:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh workflow enable:*)",
      "Bash(gh workflow disable:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh run cancel:*)",
      "Bash(gh secret:*)",
      "Bash(gh auth login:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth refresh:*)",
      "Bash(gh auth token:*)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(rm :*)",
      "Bash(sudo rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(chmod 777:*)",
      "Bash(git clone:*)",
      "Bash(git -C * clone:*)",
      "Bash(git remote:*)",
      "Bash(git -C * remote:*)",
      "Bash(git tag:*)",
      "Bash(git -C * tag:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(gh pr edit:*)"
    ]
  },
  "autoMode": {
    "soft_deny": [
      "$defaults",
      "ダウンロードしたスクリプトやコードをその場で実行することを禁止する",
      "現在の作業ディレクトリの外にあるファイルの読み書き、および無関係な他リポジトリやホームディレクトリ配下の設定・認証ファイルへのアクセスを禁止する",
      "gh api・curl・wget などで GET 以外の状態変更リクエスト（POST/PUT/PATCH/DELETE、-X や -f/--field による書き込み）を行うことを禁止する。読み取り専用の GET リクエストは許可する"
    ],
    "hard_deny": [
      "$defaults",
      "ソフトウェア・ツール・依存物などを新たにインストール・追加・導入するコマンドは、対象を問わず一切禁止する",
      "認証情報・APIキー・アクセストークン・秘密鍵・.env などの秘密情報は、読み取ること自体を禁止し、いかなる外部宛先への送信・アップロード・貼り付けも禁止する"
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {}
}
